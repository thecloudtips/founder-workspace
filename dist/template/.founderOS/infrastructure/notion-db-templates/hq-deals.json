{
  "title": "Founder OS HQ - Deals",
  "description": "Sales pipeline tracking with stage progression, probability scoring, and links to deliverables.",
  "plugin": "founder-os-hq",
  "properties": {
    "Name": {
      "type": "title",
      "description": "Deal name"
    },
    "Value": {
      "type": "number",
      "description": "Deal monetary value"
    },
    "Stage": {
      "type": "select",
      "description": "Pipeline stage",
      "options": ["Lead", "Qualified", "Proposal", "Negotiation", "Closed Won", "Closed Lost"]
    },
    "Company": {
      "type": "relation",
      "description": "Associated company",
      "relation_database": "Founder OS HQ - Companies"
    },
    "Close Date": {
      "type": "date",
      "description": "Expected or actual close date"
    },
    "Probability": {
      "type": "number",
      "description": "Win probability 0-100"
    },
    "Risk Level": {
      "type": "select",
      "description": "Deal risk assessment",
      "options": ["Low", "Medium", "High"]
    },
    "Deliverables": {
      "type": "relation",
      "description": "Linked proposals/contracts/SOWs",
      "relation_database": "Founder OS HQ - Deliverables"
    }
  },
  "default_values": {
    "Stage": "Lead",
    "Probability": 50,
    "Risk Level": "Medium"
  },
  "notes": "Part of the CRM core. Deliverables relation links to proposals, contracts, and SOWs generated by P12/P13/P14. Discovery: search 'Founder OS HQ - Deals' first, then 'Deals' or 'CRM - Deals'."
}
